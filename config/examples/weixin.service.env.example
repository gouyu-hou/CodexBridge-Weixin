# CodexBridge WeChat service environment

# The service runner loads project-local `.env` and `.env.local` first, then
# applies this service env file as an override layer. Provider API keys and
# default models can therefore live in the repo-local `.env`.

# Explicit account selection. If omitted, the runtime polls all saved accounts.
# Set WEIXIN_PRIMARY_ACCOUNT_ID to keep one account's existing thread bindings
# unprefixed while friend/shared accounts are isolated automatically.
WEIXIN_ACCOUNT_ID=
# WEIXIN_PRIMARY_ACCOUNT_ID=

# Policy
WEIXIN_DM_POLICY=open
WEIXIN_GROUP_POLICY=disabled
WEIXIN_ALLOWED_USERS=
WEIXIN_GROUP_ALLOWED_USERS=
WEIXIN_MAX_MESSAGE_LENGTH=4000
# By default WeChat receives only the final answer. Set to 1/on/true to stream
# Codex progress previews while a turn is still running.
WEIXIN_PROGRESS_PREVIEWS=0

# Local browser management panel. It is bound to localhost by default and is
# started together with `weixin serve`.
WEIXIN_ADMIN_ENABLE=1
WEIXIN_ADMIN_HOST=127.0.0.1
WEIXIN_ADMIN_PORT=43183

# Runtime throughput limits. Keep these modest unless the machine and model
# account can handle more concurrent work.
WEIXIN_MAX_CONCURRENT_TURNS=3
WEIXIN_EVENT_DISPATCH_CONCURRENCY=12
WEIXIN_ATTACHMENT_CONCURRENCY=3
WEIXIN_ACCOUNT_POLL_CONCURRENCY=4

# Log cleanup. The admin panel can update these values and applies cleanup
# automatically while the service is running.
WEIXIN_LOG_CLEANUP_ENABLE=1
WEIXIN_LOG_RETENTION_DAYS=7
WEIXIN_LOG_MAX_BYTES=10485760
WEIXIN_LOG_CLEANUP_INTERVAL_MINUTES=60

# Error alert webhook. When set, the service POSTs a JSON payload to this URL on
# runtime/poll/commit errors. Leave empty to disable. The admin panel has a
# "test" button and takes effect immediately (no restart). Identical alerts are
# debounced by WEIXIN_ALERT_MIN_INTERVAL_MS (milliseconds, default 60000).
WEIXIN_ALERT_WEBHOOK_URL=
WEIXIN_ALERT_MIN_INTERVAL_MS=60000

# Optional safety timeouts (milliseconds, 0 = disabled). Off by default to avoid
# interrupting legitimately long agent turns / long-poll windows. A wedged turn
# that exceeds WEIXIN_TURN_TIMEOUT_MS is counted as failed and frees its slot; a
# hung poll exceeding WEIXIN_POLL_TIMEOUT_MS surfaces an error and backs off.
WEIXIN_TURN_TIMEOUT_MS=0
WEIXIN_POLL_TIMEOUT_MS=0

# Default Codex provider profile for new sessions.
CODEX_DEFAULT_PROVIDER_PROFILE_ID=openai-default

# Recommended even when codex is already on PATH.
CODEX_REAL_BIN=/home/ubuntu/.nvm/versions/node/v24.11.1/bin/codex

# Optional OpenAI-compatible provider profiles. CodexBridge runs one generic
# local Responses adapter and forwards to each provider's OpenAI-compatible
# /chat/completions API. Provider-specific behavior is only capability presets,
# not separate provider plugins.
# The adapter maps Responses requests into Chat Completions and handles compact
# fallback, thinking policy, payload rules, stream errors, usage fallback, and
# model/multimodal capability metadata at the bridge layer.
# Set CODEX_DEFAULT_PROVIDER_PROFILE_ID=deepseek to make new sessions use DeepSeek.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.7
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_DEFAULT_MODEL=qwen-plus
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.kimi.com/coding
# KIMI_MODEL=kimi-k2
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-2.5-pro
# IFLOW_API_KEY=
# IFLOW_BASE_URL=https://apis.iflow.cn/v1
# IFLOW_MODEL=qwen3-coder-plus

# Optional one-off custom OpenAI-compatible profile.
# CODEX_COMPAT_PROVIDER_ID=custom
# CODEX_COMPAT_PROVIDER_NAME=Custom Provider
# CODEX_COMPAT_API_KEY=
# CODEX_COMPAT_BASE_URL=https://provider.example/v1
# CODEX_COMPAT_DEFAULT_MODEL=example-model
# CODEX_COMPAT_CAPABILITIES=default

# Optional live smoke-test credentials for the local OpenAI-compatible adapter.
# These are the same provider vars above and are only used when running:
# CODEXBRIDGE_TEST_LIVE_OPENAI_COMPATIBLE=1 pnpm exec tsx --test test/providers/openai_compatible/live_provider_smoke.test.ts

# Codex Native API localhost service. This is the Codex-subscription path, not
# the external-provider path. It is enabled by default under `weixin serve`, so
# a normal deployment starts both the bridge and the localhost native API
# together. Set CODEX_NATIVE_API_ENABLE=0 only if you explicitly want to disable
# the API surface.
# For the embedded bridge path, users still keep `/provider openai-default`;
# this localhost service is an internal execution surface behind that provider,
# not a separate user-facing provider choice.
CODEX_NATIVE_API_ENABLE=1
# CODEX_NATIVE_API_HOST=127.0.0.1
# CODEX_NATIVE_API_PORT=43182
# CODEX_NATIVE_API_AUTH_TOKEN=replace-with-a-long-random-secret
# CODEX_NATIVE_API_DEFAULT_MODEL=gpt-5.4
# CODEX_NATIVE_API_TITLE_PREFIX=Codex Native API

# Optional internal helper routing override. By default, Codex-native helper
# tasks reuse the localhost native API path automatically because
# CODEX_NATIVE_API_ENABLE defaults to enabled. Keep these only for explicit
# overrides.
# CODEXBRIDGE_INTERNAL_NATIVE_API_ENABLED=1
# CODEXBRIDGE_INTERNAL_NATIVE_API_BASE_URL=http://127.0.0.1:43182
# CODEXBRIDGE_INTERNAL_NATIVE_API_AUTH_TOKEN=replace-with-a-long-random-secret
# CODEXBRIDGE_INTERNAL_NATIVE_API_TASK_CLASSES=intent_classification,normalization,small_verification,side_reasoning

# Debugging
CODEXBRIDGE_DEBUG_WEIXIN=0
